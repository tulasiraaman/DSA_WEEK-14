class Solution {
    Map<String, Boolean> cache = new HashMap<>();
    public boolean wordBreak(String s, List<String> wordDict) {
        if(wordDict.contains(s)) return true;
        if(cache.containsKey(s)) return cache.get(s);

        for(int i = 1;i < s.length();i++){
            String str = s.substring(0, i);
            if(wordDict.contains(str) && wordBreak(s.substring(i), wordDict)){
                cache.put(s, true);
                return true;
            }
        }
        cache.put(s, false);
        return false;
    }

    public boolean wordBreakkkk(String s, List<String> wordDict) {
        Trie trie = new Trie();
        for(String word: wordDict) trie.insert(word);
        Boolean[] dp = new Boolean[s.length()];
        return dfs(0, s, trie, dp);
    }

    private boolean dfs(int idx, String s, Trie trie, Boolean[] dp) {
        if(idx == s.length()) return true;
        if(dp[idx] != null) return dp[idx];

        Node node = trie.root;
        for(int i = idx; i < s.length(); i++){
            char ch = s.charAt(i);
            if(!node.containsChar(ch)) break;
            node = node.get(ch);
            if(node.isEnd() && dfs(i+1, s, trie, dp)) return dp[idx] = true;
        }
        return dp[idx] = false;
    }
}

class Node {
    private Node[] links = new Node[26];
    private boolean flag;

    boolean containsChar(char ch){
        return (links[ch - 'a'] != null);
    }

    Node get(char ch){
        return links[ch - 'a'];
    }

    void put(char ch, Node root){
        links[ch - 'a'] = root;
    }

    void setEnd(){
        flag = true;
    }

    boolean isEnd(){
        return flag;
    }
}

class Trie {
    Node root;

    public Trie() {
        root = new Node();
    }
    
    public void insert(String word) {
        Node node = root;
        for(int i = 0; i < word.length(); i++){
            if(!node.containsChar(word.charAt(i))){
                node.put(word.charAt(i), new Node());
            }
            node = node.get(word.charAt(i));
        }
        node.setEnd();
    }
}
