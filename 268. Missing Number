class Solution {
    public int missingNumber(int[] nums) {
        int xorNum = 0;
        int xorRange = 0;
        int n = nums.length;

        for(int i = 0;i < n;i++){
            xorNum ^= nums[i];
            xorRange ^= i;
        }
        xorRange ^= n;
        return xorRange ^ xorNum;
    }
}
